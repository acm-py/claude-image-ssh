{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qy-image-upload",
  "version": "0.1.0",
  "identifier": "com.hmb.sync-image-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "qy-image-upload",
        "width": 920,
        "height": 760,
        "minWidth": 720,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
